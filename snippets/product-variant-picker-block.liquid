{%- liquid
  assign options = block.settings
  assign option_type = options.option_type
  assign show_swatches = options.show_swatches

  assign primary_option_names = settings.primary_option_name | downcase | split: ','
  assign primary_option_name_downcase = blank

  for name in primary_option_names
    assign name_striped = name | strip
    if product.options_by_name[name_striped] != blank
      assign primary_option_name_downcase = name_striped
      break
    endif
  endfor

  assign secondary_option_names = settings.secondary_option_names | newline_to_br | split: '<br />'

  assign block_option_name_downcase = block.settings.option_name | downcase
  assign information_drawer_button_label = block.settings.information_drawer_button_label
  assign information_drawer_button_position = block.settings.information_drawer_button_position
  assign information_drawer_icon_type = block.settings.information_drawer_icon_type
  assign information_drawer_button_icon = block.settings.information_drawer_button_icon
  assign information_drawer_button_custom_icon = block.settings.information_drawer_button_custom_icon

  assign hide_single_value_options = block.settings.hide_single_value_options
  assign show_variant_picker = true

  if hide_single_value_options
    assign show_variant_picker = false

    for option in product.options_with_values
      for value in option.values
        if option.values.size > 1
          assign show_variant_picker = true
          break
        endif
      endfor
    endfor
  endif
-%}

{% if information_drawer_button_label != blank
  or information_drawer_icon_type != 'none'
  or information_drawer_button_custom_icon != blank
%}
  {% capture drawer_button %}
    <sidebar-button class='product-variant-picker__popup-toggle-wrapper {% if information_drawer_button_position != 'left' %}product-variant-picker__popup-toggle-wrapper--right{% endif %}'>
      <button
        data-sidebar-button
        data-sidebar-id='product-variant-picker-popup-{{ product.id }}-{{ sectionId }}'
        class='unstyled-button product-variant-picker__popup-toggle'
        type='button'
      >
        {% if information_drawer_icon_type != 'none' %}
          {% if information_drawer_icon_type == 'custom' and information_drawer_button_custom_icon != blank %}
            <img
              {% render 'image-attributes',
                image: information_drawer_button_custom_icon,
                size: 'xsmall',
                class: 'product-variant-picker__popup-toggle-icon'
              %}
            >
          {% elsif information_drawer_icon_type == 'preset' %}
            {% render 'icon-pack', icon: information_drawer_button_icon, class: 'product-variant-picker__popup-toggle-icon' %}
          {% endif %}
        {% endif %}

        <span>{{ information_drawer_button_label }}</span>
      </button>
    </sidebar-button>
  {% endcapture %}
{% endif %}

{% if show_variant_picker %}
  {%- if product != blank and product.has_only_default_variant == false -%}
    <variant-picker
      data-product-block='{{ block.id }}'
      class='product-variant-picker block-{{ block.id }} {% if block.settings.option_type contains 'dropdown' %}product-variant-picker--with-dropdown-options{% endif %}'
      data-section='{{ sectionId }}'
      data-section-id-without-prefix='{{ section.id }}'
      data-product-id='{{ product.id }}'
      data-url='{{ product.url }}'
      id='product-variant-picker-{{ sectionId }}'
      data-update-url='{% if sectionId contains 'MainSection' %}true{% else %}false{% endif %}'
      {% if section.settings.show_variant_media_by_featured_order %}
        data-product-media-filtering-option
      {% elsif section.settings.show_only_selected_variants and media_array.size != product.media.size %}
        data-product-media-filtering-option
      {% endif %}
      {% if product.selected_variant != blank %}
        data-selected-variant='{{ product.selected_variant.id }}'
        {% if product.selected_variant.featured_media != blank %}
          data-selected-variant-image-id='{{ product.selected_variant.featured_media.id }}'
        {% elsif product.selected_variant.featured_image != blank %}
          data-selected-variant-image-id='{{ product.selected_variant.featured_image.id }}'
        {% endif %}
      {% endif %}
      {{ block.shopify_attributes }}
    >
      <div class='product-variant-picker__form'>
        {%- for option in product.options_with_values -%}
          <div data-variant-picker-option-inputs>
            {{ option.name }}

            {%- for value in option.values -%}
              <div>
                <input
                  type='radio'
                  id='{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
                  name='{{ option.name }}-{{ option.position }}'
                  value='{{ value | escape }}'
                  form='product-form-{{ product.id }}-{{ sectionId }}'
                  data-value-id='{{ value.id }}'
                  data-product-url='{{ value.product_url }}'
                  {% if value.selected %}
                    checked
                  {% endif %}
                >
                {{ value }}
              </div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>

      <div class='product-variant-picker__list'>
        {%- for option in product.options_with_values -%}
          {% liquid
            assign option_name_downcase = option.name | downcase
            assign color_option_picker_type = ''

            assign is_swatch = false
            assign is_primary_swatch = false

            if option_name_downcase == primary_option_name_downcase and show_swatches
              assign is_primary_swatch = true
              assign is_swatch = true
            else
              for secondary_option_name in secondary_option_names
                assign secondary_option_name_downcase = secondary_option_name | downcase | strip

                if secondary_option_name_downcase == option_name_downcase and show_swatches
                  assign is_swatch = true

                  break
                endif
              endfor
            endif

            assign swatch_count = option.values | map: 'swatch' | compact | size
            if swatch_count > 0 and show_swatches
              assign is_swatch = true
              assign is_primary_swatch = true
            endif

            if is_swatch
              if is_primary_swatch
                assign color_option_picker_type = block.settings.primary_swatch_option_type
              else
                assign color_option_picker_type = block.settings.secondary_swatch_option_type
              endif
            endif

            assign use_svg_row_for_option = false
            if block.settings.enable_option_svg_row and block.settings.option_svg_target_name != blank
              assign svg_target = block.settings.option_svg_target_name | strip | downcase
              if svg_target == option_name_downcase
                assign use_svg_row_for_option = true
              endif
            endif
          %}

          <div
            class='{% if hide_single_value_options == true and option.values.size < 2 %}visually-hidden{% endif %}'
            data-variant-picker-option-labels
            option-picker-name='{{ option.name }}'
          >
            {%- if is_swatch -%}
              {%-
                render 'product-color-swatches',
                product: product,
                option: option,
                color_option_picker_type: color_option_picker_type,
                is_primary_swatch: is_primary_swatch,
                block: block,
                sectionId: sectionId,
              -%}
            {%- elsif use_svg_row_for_option -%}
              {%-
                render 'product-variant-option-svg-row',
                product: product,
                option: option,
                block: block,
                sectionId: sectionId,
                block_option_name_downcase: block_option_name_downcase,
                drawer_button: drawer_button
              -%}
            {%- elsif block.settings.option_type contains 'button' -%}
              <div class='product-variant-picker__option-label'>
                <span class='heading-font-family'>{{ option.name }}</span>

                {%- assign option_name_downcase = option.name | downcase -%}

                {%- if block_option_name_downcase == option_name_downcase -%}
                  {{ drawer_button }}
                {%- endif -%}
              </div>

              <div class='product-variant-picker__pill-list'>
                {%- for value in option.values -%}
                  <label
                    for='{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
                    class='pill pill--large {% if value.selected %} selected {% endif %} {% if option_type == 'button-outline' %} pill--outline {% elsif option_type == 'button-solid' %} pill--solid {% elsif option_type == 'button-underline' %} pill--underline {% endif %}'
                    {% if value.selected %}
                      tabindex='0'
                    {% endif %}
                    {% unless value.available %}
                      no-available
                    {% endunless %}
                  >
                    <span class='pill__label'>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>

            {%- else -%}
              <div class='product-variant-picker__option-label'>
                <span class='heading-font-family'>{{ option.name }}</span>

                {%- assign option_name_downcase = option.name | downcase -%}

                {%- if block_option_name_downcase == option_name_downcase -%}
                  {{ drawer_button }}
                {%- endif -%}
              </div>
              <dropdown-opener
                class='variant-picker-dropdown__toggle {% if option_type == 'dropdown-underline' %} variant-picker-dropdown__toggle--underline {% elsif option_type == 'dropdown-outline' %} variant-picker-dropdown__toggle--outline {% elsif option_type == 'dropdown-solid' %} variant-picker-dropdown__toggle--solid {% endif %}'
                data-aria-expanded='false'
                data-float-element-id='variant-picker-dropdown-{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
                data-trigger='click'
                tabindex='0'
                {% if sectionId contains 'QuickView' %}
                  data-set-width
                {% endif %}
              >
                <div class='variant-picker-dropdown__toggle-label' data-dropdown-variant-picker-label>
                  <span>{{ option.selected_value }}</span>
                </div>
                {%- render 'icon', icon_name: 'chevron', class: 'variant-picker-dropdown__chevron' -%}
              </dropdown-opener>
              <float-element
                class='variant-picker-dropdown {% if option_type == 'dropdown-underline' %} variant-picker-dropdown--underline {% elsif option_type == 'dropdown-outline' %} variant-picker-dropdown--outline {% elsif option_type == 'dropdown-solid' %} variant-picker-dropdown--solid {% endif %}'
                aria-hidden='true'
                id='variant-picker-dropdown-{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
                data-placement='bottom-start'
                data-main-axis-offset='{% if settings.round_level != "0" %} 8{% else %} 0{% endif %}'
                data-strategy='fixed'
                {% if sectionId contains 'QuickView' %}
                  data-with-portal
                {% endif %}
              >
                <template data-float-element-template='variant-picker-dropdown-{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'>
                  <div class='variant-picker-dropdown__body'>
                    {%- for value in option.values -%}
                      <label
                        class='variant-picker-dropdown__item {% if value.selected %} selected {% endif %}'
                        for='{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
                        tabindex='0'
                        data-focus-trap-target
                        {% unless value.available %}
                          no-available
                        {% endunless %}
                      >
                        <span>{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </template>
              </float-element>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <script type='application/json' data-selected-variant-json>
        {{ product.selected_or_first_available_variant | json }}
      </script>
    </variant-picker>
  {%- endif -%}
{% endif %}

{%- if block.settings.enable_bundle and product != blank and product.has_only_default_variant == false -%}
  {%- liquid
    assign bundle_primary_pos = nil
    assign bundle_primary_name = ''
    for option in product.options_with_values
      assign opt_d = option.name | downcase
      if opt_d == primary_option_name_downcase
        assign bundle_primary_pos = option.position
        assign bundle_primary_name = option.name
        break
      endif
    endfor

    assign bundle_columns = block.settings.bundle_columns | default: 3
    assign bundle_btn_label = block.settings.bundle_button_label | default: 'Læg i kurv'
    assign bundle_btn_style = block.settings.bundle_button_style | default: 'primary'
    assign first_step_count = block.settings.bundle_step_1_count | default: 1
  -%}

  {% capture bundle_css %}
    {% style %}
      .block-{{ block.id }} [option-picker-name="{{ bundle_primary_name }}"] {
        display: none !important;
      }
      .bundle-picker-{{ block.id }} {
        --bundle-cols: {{ bundle_columns }};
      }
      .bundle-picker-{{ block.id }} .bundle-picker__steps {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        padding: 8px 12px;
        border: 1px solid var(--gsc-border-color-100);
        background: transparent;
        cursor: pointer;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
        font-family: var(--gsc-button-font-family);
        font-weight: var(--gsc-button-font-weight);
        letter-spacing: var(--gsc-button-letter-spacing);
        text-transform: var(--gsc-button-text-transform);
        font-size: calc(var(--gsc-button-font-size) * 0.85);
        line-height: var(--gsc-button-line-height);
        color: var(--gsc-text-color-100);
        border-radius: inherit;
        flex: 1;
        min-width: 0;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__step:hover {
        background: var(--gsc-foreground-color-5);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__step--active {
        background: var(--gsc-primary-button-bg-color);
        color: var(--gsc-primary-button-text-color);
        border-color: var(--gsc-primary-button-bg-color);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__step--active:hover {
        background: var(--gsc-primary-button-bg-hover);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__step-price {
        font-size: 0.78em;
        opacity: 0.7;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__status {
        text-align: center;
        margin-bottom: 12px;
        font-family: var(--gsc-body-font-family);
        font-size: calc(1.3rem * var(--gsc-body-font-scale));
        color: var(--gsc-text-color-70);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__status-count {
        font-weight: var(--gsc-headings-font-weight, 600);
        color: var(--gsc-text-color-100);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__grid {
        display: grid;
        grid-template-columns: repeat(var(--bundle-cols), 1fr);
        gap: 8px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card {
        text-align: center;
        border-radius: inherit;
        transition: box-shadow 0.2s;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card[hidden] {
        display: none;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card--selected {
        box-shadow: 0 0 0 2px var(--gsc-primary-button-bg-color);
        border-radius: inherit;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card-img {
        overflow: hidden;
        border-radius: inherit;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card-img img {
        width: 100%;
        display: block;
        object-fit: cover;
        aspect-ratio: 1;
        border-radius: inherit;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card-info {
        padding: 5px 2px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card-title {
        font-family: var(--gsc-body-font-family);
        font-size: calc(1.15rem * var(--gsc-body-font-scale));
        color: var(--gsc-text-color-100);
        display: block;
        line-height: 1.3;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 4px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__qty-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border: 1px solid var(--gsc-border-color-100);
        background: transparent;
        color: var(--gsc-text-color-100);
        font-size: 15px;
        line-height: 1;
        cursor: pointer;
        transition: background 0.15s, opacity 0.15s;
        border-radius: inherit;
        padding: 0;
        font-family: var(--gsc-body-font-family);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__qty-btn:hover:not(:disabled) {
        background: var(--gsc-foreground-color-10);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__qty-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__qty-count {
        font-family: var(--gsc-body-font-family);
        font-size: calc(1.2rem * var(--gsc-body-font-scale));
        font-weight: var(--gsc-headings-font-weight, 600);
        min-width: 14px;
        text-align: center;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__card--unavailable {
        opacity: 0.4;
        pointer-events: none;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__cta {
        margin-top: 14px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__add-to-cart {
        width: 100%;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__add-to-cart.loading .bundle-picker__btn-text {
        visibility: hidden;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__add-to-cart .loading-spinner { display: none; }
      .bundle-picker-{{ block.id }} .bundle-picker__add-to-cart.loading .loading-spinner { display: block; }
      .bundle-picker-{{ block.id }} .bundle-picker__pricing {
        text-align: center;
        margin-top: 12px;
        margin-bottom: 4px;
        font-family: var(--gsc-body-font-family);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__price-per-item {
        font-size: calc(1.3rem * var(--gsc-body-font-scale));
        color: var(--gsc-text-color-70);
      }
      .bundle-picker-{{ block.id }} .bundle-picker__price-total {
        font-size: calc(1.6rem * var(--gsc-body-font-scale));
        font-weight: var(--gsc-headings-font-weight, 600);
        color: var(--gsc-text-color-100);
        margin-top: 2px;
      }
      .bundle-picker-{{ block.id }} .bundle-picker__price-savings {
        font-size: calc(1.2rem * var(--gsc-body-font-scale));
        color: var(--gsc-sale-text-color, #e53935);
        margin-top: 2px;
      }
    {% endstyle %}
  {% endcapture %}
  {% render 'inline-css-minifier', css: bundle_css %}

  <bundle-variant-picker
    class='bundle-picker-{{ block.id }}'
    data-block-id='{{ block.id }}'
    data-primary-option-position='{{ bundle_primary_pos }}'
    data-section-id='{{ sectionId }}'
  >
    {%- liquid
      assign first_unit_price = block.settings.bundle_step_1_unit_price | default: 0
    -%}
    {%- if block.settings.bundle_step_1_label != blank -%}
      <div class='bundle-picker__steps'>
        <button type='button' class='bundle-picker__step bundle-picker__step--active' data-bundle-step data-bundle-step-count='{{ block.settings.bundle_step_1_count }}' data-bundle-unit-price='{{ block.settings.bundle_step_1_unit_price | default: 0 }}'>
          <span>{{ block.settings.bundle_step_1_label }}</span>
          {%- if block.settings.bundle_step_1_price != blank -%}<span class='bundle-picker__step-price'>{{ block.settings.bundle_step_1_price }}</span>{%- endif -%}
        </button>
        {%- if block.settings.bundle_step_2_label != blank -%}
          <button type='button' class='bundle-picker__step' data-bundle-step data-bundle-step-count='{{ block.settings.bundle_step_2_count }}' data-bundle-unit-price='{{ block.settings.bundle_step_2_unit_price | default: 0 }}'>
            <span>{{ block.settings.bundle_step_2_label }}</span>
            {%- if block.settings.bundle_step_2_price != blank -%}<span class='bundle-picker__step-price'>{{ block.settings.bundle_step_2_price }}</span>{%- endif -%}
          </button>
        {%- endif -%}
        {%- if block.settings.bundle_step_3_label != blank -%}
          <button type='button' class='bundle-picker__step' data-bundle-step data-bundle-step-count='{{ block.settings.bundle_step_3_count }}' data-bundle-unit-price='{{ block.settings.bundle_step_3_unit_price | default: 0 }}'>
            <span>{{ block.settings.bundle_step_3_label }}</span>
            {%- if block.settings.bundle_step_3_price != blank -%}<span class='bundle-picker__step-price'>{{ block.settings.bundle_step_3_price }}</span>{%- endif -%}
          </button>
        {%- endif -%}
        {%- if block.settings.bundle_step_4_label != blank -%}
          <button type='button' class='bundle-picker__step' data-bundle-step data-bundle-step-count='{{ block.settings.bundle_step_4_count }}' data-bundle-unit-price='{{ block.settings.bundle_step_4_unit_price | default: 0 }}'>
            <span>{{ block.settings.bundle_step_4_label }}</span>
            {%- if block.settings.bundle_step_4_price != blank -%}<span class='bundle-picker__step-price'>{{ block.settings.bundle_step_4_price }}</span>{%- endif -%}
          </button>
        {%- endif -%}
      </div>
      <div class='bundle-picker__status'>
        Valgt: <span class='bundle-picker__status-count' data-bundle-counter>0 / {{ first_step_count }}</span>
      </div>
    {%- endif -%}

    <div class='bundle-picker__grid' data-bundle-grid>
      {%- for v in product.variants -%}
        {%- liquid
          assign v_image = v.featured_image | default: product.featured_image
          assign v_color = ''
          case bundle_primary_pos
            when 1
              assign v_color = v.option1
            when 2
              assign v_color = v.option2
            when 3
              assign v_color = v.option3
          endcase
        -%}
        <div
          class='bundle-picker__card {% unless v.available %}bundle-picker__card--unavailable{% endunless %}'
          data-bundle-product
          data-variant-id='{{ v.id }}'
          data-option1='{{ v.option1 | escape }}'
          {% if v.option2 %}data-option2='{{ v.option2 | escape }}'{% endif %}
          {% if v.option3 %}data-option3='{{ v.option3 | escape }}'{% endif %}
          hidden
        >
          <div class='bundle-picker__card-img'>
            {%- if v_image != blank -%}
              <img
                src='{{ v_image | image_url: width: 400 }}'
                alt='{{ v_color | escape }}'
                width='200'
                height='200'
                loading='lazy'
              >
            {%- else -%}
              {{ 'product-4' | placeholder_svg_tag: 'placeholder-image' }}
            {%- endif -%}
          </div>
          <div class='bundle-picker__card-info'>
            <span class='bundle-picker__card-title'>{{ v_color }}</span>
            <div class='bundle-picker__controls'>
              <button type='button' class='bundle-picker__qty-btn' data-bundle-remove disabled aria-label='Fjern'>−</button>
              <span class='bundle-picker__qty-count' data-bundle-item-count>0</span>
              <button type='button' class='bundle-picker__qty-btn' data-bundle-add aria-label='Tilføj'>+</button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class='bundle-picker__pricing' data-bundle-pricing style='display:none;'>
      <div class='bundle-picker__price-per-item' data-bundle-price-per-item></div>
      <div class='bundle-picker__price-total' data-bundle-price-total></div>
      <div class='bundle-picker__price-savings' data-bundle-price-savings></div>
    </div>

    <div class='bundle-picker__cta'>
      <button
        type='button'
        class='btn btn--md btn--{{ bundle_btn_style }} bundle-picker__add-to-cart'
        data-bundle-add-to-cart
        disabled
      >
        <span class='bundle-picker__btn-text'>{{ bundle_btn_label }}</span>
        <div class='loading-spinner btn__loading-spinner'></div>
      </button>
    </div>
  </bundle-variant-picker>

  <script>
    if (!customElements.get('bundle-variant-picker')) {
      class BundleVariantPicker extends HTMLElement {
        connectedCallback() {
          this.selectedItems = {};
          this.primaryPos = this.dataset.primaryOptionPosition;
          this.cards = this.querySelectorAll('[data-bundle-product]');
          this.addToCartBtn = this.querySelector('[data-bundle-add-to-cart]');
          this.counterDisplay = this.querySelector('[data-bundle-counter]');
          this.pricingEl = this.querySelector('[data-bundle-pricing]');
          this.pricePerItemEl = this.querySelector('[data-bundle-price-per-item]');
          this.priceTotalEl = this.querySelector('[data-bundle-price-total]');
          this.priceSavingsEl = this.querySelector('[data-bundle-price-savings]');

          this.stepButtons = this.querySelectorAll('[data-bundle-step]');
          const firstStep = this.stepButtons[0];
          this.maxItems = parseInt(firstStep?.dataset.bundleStepCount || '1');
          this.unitPrice = parseInt(firstStep?.dataset.bundleUnitPrice || '0');
          this.baseUnitPrice = this.unitPrice;

          if (this.stepButtons.length > 0) {
            let highest = 0;
            this.stepButtons.forEach(btn => {
              const p = parseInt(btn.dataset.bundleUnitPrice || '0');
              if (p > highest) highest = p;
            });
            this.baseUnitPrice = highest;
          }

          this.stepButtons.forEach(btn => btn.addEventListener('click', () => this.selectStep(btn)));

          this.cards.forEach(card => {
            card.querySelector('[data-bundle-add]')?.addEventListener('click', e => {
              e.stopPropagation();
              this.addItem(card);
            });
            card.querySelector('[data-bundle-remove]')?.addEventListener('click', e => {
              e.stopPropagation();
              this.removeItem(card);
            });
          });

          this.addToCartBtn?.addEventListener('click', () => this.addToCart());

          const variantPicker = this.closest('[data-product-block]')?.closest('.product__info')
            ?.querySelector('variant-picker') || document.querySelector('variant-picker');
          if (variantPicker) {
            variantPicker.querySelectorAll('[data-variant-picker-option-inputs] input[type="radio"]').forEach(input => {
              input.addEventListener('change', () => this.onOptionChange());
            });
          }

          this.onOptionChange();
        }

        formatPrice(kr) {
          return kr.toLocaleString('da-DK') + ' kr';
        }

        getSelectedOptions() {
          const selected = {};
          const variantPicker = this.closest('[data-product-block]')?.closest('.product__info')
            ?.querySelector('variant-picker') || document.querySelector('variant-picker');
          if (!variantPicker) return selected;

          variantPicker.querySelectorAll('[data-variant-picker-option-inputs]').forEach(group => {
            const checked = group.querySelector('input[type="radio"]:checked');
            if (checked) {
              const nameAttr = checked.name;
              const match = nameAttr.match(/-(\d+)$/);
              if (match) {
                selected[match[1]] = checked.value;
              }
            }
          });
          return selected;
        }

        onOptionChange() {
          const sel = this.getSelectedOptions();
          this.cards.forEach(card => {
            let show = true;
            for (const [pos, val] of Object.entries(sel)) {
              if (pos === this.primaryPos) continue;
              const cardVal = card.dataset['option' + pos];
              if (cardVal && cardVal !== val) {
                show = false;
                break;
              }
            }
            card.hidden = !show;
          });

          Object.keys(this.selectedItems).forEach(vid => {
            const card = this.querySelector(`[data-variant-id="${vid}"]`);
            if (card && card.hidden) {
              delete this.selectedItems[vid];
            }
          });
          this.updateUI();
        }

        selectStep(btn) {
          const newMax = parseInt(btn.dataset.bundleStepCount);
          const newUnitPrice = parseInt(btn.dataset.bundleUnitPrice || '0');
          this.stepButtons.forEach(b => b.classList.remove('bundle-picker__step--active'));
          btn.classList.add('bundle-picker__step--active');
          this.maxItems = newMax;
          this.unitPrice = newUnitPrice;
          if (this.getTotalItems() > newMax) this.selectedItems = {};
          this.updateUI();
        }

        addItem(card) {
          if (this.getTotalItems() >= this.maxItems) return;
          const vid = card.dataset.variantId;
          this.selectedItems[vid] = (this.selectedItems[vid] || 0) + 1;
          this.updateUI();
        }

        removeItem(card) {
          const vid = card.dataset.variantId;
          if (!this.selectedItems[vid] || this.selectedItems[vid] <= 0) return;
          this.selectedItems[vid]--;
          if (this.selectedItems[vid] === 0) delete this.selectedItems[vid];
          this.updateUI();
        }

        getTotalItems() {
          return Object.values(this.selectedItems).reduce((s, q) => s + q, 0);
        }

        updateUI() {
          const total = this.getTotalItems();
          const atMax = total >= this.maxItems;

          if (this.counterDisplay) {
            this.counterDisplay.textContent = total + ' / ' + this.maxItems;
          }

          this.cards.forEach(card => {
            if (card.hidden) return;
            const vid = card.dataset.variantId;
            const qty = this.selectedItems[vid] || 0;
            const addBtn = card.querySelector('[data-bundle-add]');
            const removeBtn = card.querySelector('[data-bundle-remove]');
            const countEl = card.querySelector('[data-bundle-item-count]');
            if (countEl) countEl.textContent = qty;
            if (addBtn) addBtn.disabled = atMax || card.classList.contains('bundle-picker__card--unavailable');
            if (removeBtn) removeBtn.disabled = qty <= 0;
            card.classList.toggle('bundle-picker__card--selected', qty > 0);
          });

          if (this.addToCartBtn) this.addToCartBtn.disabled = total === 0;

          if (this.pricingEl && this.unitPrice > 0) {
            if (total > 0) {
              this.pricingEl.style.display = '';
              const totalPrice = total * this.unitPrice;
              this.pricePerItemEl.textContent = total + ' × ' + this.formatPrice(this.unitPrice);
              this.priceTotalEl.textContent = 'Total: ' + this.formatPrice(totalPrice);

              const fullPrice = total * this.baseUnitPrice;
              if (this.unitPrice < this.baseUnitPrice && total > 0) {
                const saved = fullPrice - totalPrice;
                this.priceSavingsEl.textContent = 'Du sparer ' + this.formatPrice(saved);
                this.priceSavingsEl.style.display = '';
              } else {
                this.priceSavingsEl.style.display = 'none';
              }
            } else {
              this.pricingEl.style.display = 'none';
            }
          }
        }

        async addToCart() {
          const items = Object.entries(this.selectedItems)
            .filter(([, qty]) => qty > 0)
            .map(([id, quantity]) => ({ id: parseInt(id), quantity }));
          if (!items.length) return;

          this.addToCartBtn.disabled = true;
          this.addToCartBtn.classList.add('loading');

          try {
            const res = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items }),
            });
            if (!res.ok) throw new Error('Cart error');

            const cart = await (await fetch('/cart.js')).json();
            document.querySelectorAll('[data-cart-count]').forEach(el => { el.textContent = cart.item_count; });
            document.dispatchEvent(new CustomEvent('cart:change', { detail: { cart } }));
            document.dispatchEvent(new CustomEvent('cart:items-changed', { detail: { cart } }));

            this.selectedItems = {};
            this.updateUI();

            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer?.open) cartDrawer.open();
            else window.location.href = '/cart';
          } catch (err) {
            console.error('Bundle add-to-cart failed:', err);
          } finally {
            this.addToCartBtn.disabled = false;
            this.addToCartBtn.classList.remove('loading');
          }
        }
      }
      customElements.define('bundle-variant-picker', BundleVariantPicker);
    }
  </script>
{%- endif -%}

