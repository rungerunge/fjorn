{%- liquid
  assign option_name_match = option.name | downcase
-%}

<div class='product-variant-picker__option-label'>
  <span class='heading-font-family'>{{ option.name }}</span>
  {%- if block_option_name_downcase == option_name_match -%}
    {{ drawer_button }}
  {%- endif -%}
</div>

<div
  class='product-variant-picker__svg-row'
  data-product-variant-svg-row
>
  {%- for value in option.values -%}
    {%- liquid
      assign vnorm = value | strip | downcase
      assign svg_icon = blank
      assign m1 = block.settings.option_svg_match_1 | default: '' | strip | downcase
      assign m2 = block.settings.option_svg_match_2 | default: '' | strip | downcase
      assign m3 = block.settings.option_svg_match_3 | default: '' | strip | downcase
      assign m4 = block.settings.option_svg_match_4 | default: '' | strip | downcase
      assign m5 = block.settings.option_svg_match_5 | default: '' | strip | downcase
      assign m6 = block.settings.option_svg_match_6 | default: '' | strip | downcase
      if m1 != '' and vnorm == m1 and block.settings.option_svg_image_1 != blank
        assign svg_icon = block.settings.option_svg_image_1
      elsif m2 != '' and vnorm == m2 and block.settings.option_svg_image_2 != blank
        assign svg_icon = block.settings.option_svg_image_2
      elsif m3 != '' and vnorm == m3 and block.settings.option_svg_image_3 != blank
        assign svg_icon = block.settings.option_svg_image_3
      elsif m4 != '' and vnorm == m4 and block.settings.option_svg_image_4 != blank
        assign svg_icon = block.settings.option_svg_image_4
      elsif m5 != '' and vnorm == m5 and block.settings.option_svg_image_5 != blank
        assign svg_icon = block.settings.option_svg_image_5
      elsif m6 != '' and vnorm == m6 and block.settings.option_svg_image_6 != blank
        assign svg_icon = block.settings.option_svg_image_6
      endif
    -%}
    <label
      for='{{ sectionId }}-{{ product.id }}-{{ option.position }}-{{ forloop.index0 }}'
      class='
        product-variant-picker__svg-option
        {% if value.selected %} selected {% endif %}
      '
      {% if value.selected %}
        tabindex='0'
      {% endif %}
      {% unless value.available %}
        no-available
      {% endunless %}
    >
      {% if svg_icon != blank %}
        <span class='product-variant-picker__svg-icon' aria-hidden='true'>
          <img
            src='{{ svg_icon | image_url: width: 320 }}'
            alt=''
            width='96'
            height='96'
            loading='lazy'
            decoding='async'
          >
        </span>
      {% endif %}
      <span class='product-variant-picker__svg-label'>{{ value }}</span>
    </label>
  {%- endfor -%}
</div>

{% stylesheet %}
  /* Minimal row: icon + label only (no boxes), cf. rockluggage-style variant row */
  [data-product-variant-svg-row] {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.5rem 1.5rem;
  }

  .product-variant-picker__svg-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    min-width: 3.25rem;
    padding: 0;
    margin: 0;
    text-align: center;
    background: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
    cursor: pointer;
    opacity: 1;
  }

  .product-variant-picker__svg-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 5.5rem;
    height: 5.5rem;
  }

  /* Unselected: lette ikoner; valgt: fuld sort (fill) som Rock */
  .product-variant-picker__svg-icon img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.62;
    filter: none;
    transition: opacity 0.15s ease, filter 0.15s ease;
  }

  .product-variant-picker__svg-option.selected .product-variant-picker__svg-icon img {
    opacity: 1;
    filter: brightness(0);
  }

  /*
    Eksplicitte farver: theme-variabler (fx --gsc-foreground-color) kan være lyse i visse
    farveskemaer, og rgba(var(...)) i scoped stylesheet giver ofte næsten hvid tekst.
  */
  [data-product-variant-svg-row] .product-variant-picker__svg-label {
    display: block;
    line-height: 1.3;
    font-size: 14px !important;
    font-weight: 500;
    color: #333333 !important;
    transition: color 0.15s ease;
  }

  [data-product-variant-svg-row]
    .product-variant-picker__svg-option:not([no-available]):hover
    .product-variant-picker__svg-label {
    color: #000000 !important;
    font-weight: 600;
  }

  [data-product-variant-svg-row] .product-variant-picker__svg-option.selected .product-variant-picker__svg-label {
    font-size: 14px !important;
    color: #000000 !important;
    font-weight: 600;
  }

  .product-variant-picker__svg-option[no-available] {
    cursor: not-allowed;
  }

  .product-variant-picker__svg-option[no-available] .product-variant-picker__svg-icon {
    position: relative;
  }

  .product-variant-picker__svg-option[no-available] .product-variant-picker__svg-icon img {
    opacity: 0.38;
    filter: grayscale(0.25);
  }

  /* Skrå streg kun på ikon — ikke i teksten */
  .product-variant-picker__svg-option[no-available] .product-variant-picker__svg-icon::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 1;
    width: 92%;
    max-width: 4.5rem;
    height: 1px;
    background: rgba(0, 0, 0, 0.38);
    transform: translate(-50%, -50%) rotate(-45deg);
    pointer-events: none;
    border-radius: 0.5px;
  }

  [data-product-variant-svg-row] .product-variant-picker__svg-option[no-available] .product-variant-picker__svg-label {
    color: #9a9a9a !important;
    font-weight: 400;
    opacity: 0.72;
  }
{% endstylesheet %}
