{%- liquid
  assign s = block.settings
  assign heading = s.heading | default: 'Key Elements'
-%}

{%- assign has_items = false -%}
{%- for i in (1..4) -%}
  {%- case i -%}
    {%- when 1 -%}{%- assign img = s.image_1 -%}{%- assign title = s.title_1 -%}{%- assign text = s.text_1 -%}
    {%- when 2 -%}{%- assign img = s.image_2 -%}{%- assign title = s.title_2 -%}{%- assign text = s.text_2 -%}
    {%- when 3 -%}{%- assign img = s.image_3 -%}{%- assign title = s.title_3 -%}{%- assign text = s.text_3 -%}
    {%- when 4 -%}{%- assign img = s.image_4 -%}{%- assign title = s.title_4 -%}{%- assign text = s.text_4 -%}
  {%- endcase -%}
  {%- if img != blank or title != blank -%}
    {%- assign has_items = true -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_items -%}
  <div
    data-product-block='{{ block.id }}'
    class='key-elements block-{{ block.id }}'
    {{ block.shopify_attributes }}
  >
    <p class='key-elements__heading caption2 heading-font-family'>{{ heading | escape }}</p>
    <div class='key-elements__grid'>
      {%- for i in (1..4) -%}
        {%- case i -%}
          {%- when 1 -%}{%- assign img = s.image_1 -%}{%- assign title = s.title_1 -%}{%- assign text = s.text_1 -%}
          {%- when 2 -%}{%- assign img = s.image_2 -%}{%- assign title = s.title_2 -%}{%- assign text = s.text_2 -%}
          {%- when 3 -%}{%- assign img = s.image_3 -%}{%- assign title = s.title_3 -%}{%- assign text = s.text_3 -%}
          {%- when 4 -%}{%- assign img = s.image_4 -%}{%- assign title = s.title_4 -%}{%- assign text = s.text_4 -%}
        {%- endcase -%}

        {%- if img != blank or title != blank -%}
          <div class='key-elements__card'>
            {%- if img != blank -%}
              <div class='key-elements__card-image'>
                <img
                  src='{{ img | image_url: width: 400 }}'
                  alt='{{ title | default: "" | strip_html | escape }}'
                  width='200'
                  height='200'
                  loading='lazy'
                >
              </div>
            {%- endif -%}
            {%- if title != blank -%}
              <p class='key-elements__card-title body3 heading-font-family'>{{ title | escape }}</p>
            {%- endif -%}
            {%- if text != blank -%}
              <p class='key-elements__card-text body3 body-color'>{{ text | escape }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .key-elements {
    width: 100%;
  }
  .key-elements__heading {
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .key-elements__grid {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }
  .key-elements__grid::-webkit-scrollbar {
    display: none;
  }
  .key-elements__card {
    flex: 0 0 45%;
    min-width: 0;
    scroll-snap-align: start;
  }
  @media (min-width: 750px) {
    .key-elements__grid {
      overflow-x: visible;
      scroll-snap-type: none;
      flex-wrap: wrap;
    }
    .key-elements__card {
      flex: 0 0 calc(50% - 8px);
    }
  }
  .key-elements__card-image {
    background: #f5f5f5;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }
  .key-elements__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .key-elements__card-title {
    font-weight: 600;
    margin: 0 0 4px;
  }
  .key-elements__card-text {
    margin: 0;
    font-size: 11px;
    line-height: 1.4;
  }
{% endstylesheet %}
