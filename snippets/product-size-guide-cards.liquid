{%- comment -%}
  RIMOWA-style size guide with cards.
  Data comes from variant_picker block settings (sg_card_N_*).
{%- endcomment -%}

{%- liquid
  assign has_cards = false
  for i in (1..6)
    case i
      when 1
        assign card_name = block.settings.sg_card_1_name
      when 2
        assign card_name = block.settings.sg_card_2_name
      when 3
        assign card_name = block.settings.sg_card_3_name
      when 4
        assign card_name = block.settings.sg_card_4_name
      when 5
        assign card_name = block.settings.sg_card_5_name
      when 6
        assign card_name = block.settings.sg_card_6_name
    endcase
    if card_name != blank
      assign has_cards = true
      break
    endif
  endfor
-%}

{%- if has_cards -%}
  <div class='size-guide-cards'>
    <div class='size-guide-cards__heading heading-font-family'>{{ product.title }}</div>
    <div class='size-guide-cards__grid'>
      {%- for i in (1..6) -%}
        {%- liquid
          case i
            when 1
              assign card_name = block.settings.sg_card_1_name
              assign card_image = block.settings.sg_card_1_image
              assign card_dim = block.settings.sg_card_1_dimensions
              assign card_weight = block.settings.sg_card_1_weight
              assign card_volume = block.settings.sg_card_1_volume
              assign card_outfits = block.settings.sg_card_1_outfits
              assign card_days = block.settings.sg_card_1_days
            when 2
              assign card_name = block.settings.sg_card_2_name
              assign card_image = block.settings.sg_card_2_image
              assign card_dim = block.settings.sg_card_2_dimensions
              assign card_weight = block.settings.sg_card_2_weight
              assign card_volume = block.settings.sg_card_2_volume
              assign card_outfits = block.settings.sg_card_2_outfits
              assign card_days = block.settings.sg_card_2_days
            when 3
              assign card_name = block.settings.sg_card_3_name
              assign card_image = block.settings.sg_card_3_image
              assign card_dim = block.settings.sg_card_3_dimensions
              assign card_weight = block.settings.sg_card_3_weight
              assign card_volume = block.settings.sg_card_3_volume
              assign card_outfits = block.settings.sg_card_3_outfits
              assign card_days = block.settings.sg_card_3_days
            when 4
              assign card_name = block.settings.sg_card_4_name
              assign card_image = block.settings.sg_card_4_image
              assign card_dim = block.settings.sg_card_4_dimensions
              assign card_weight = block.settings.sg_card_4_weight
              assign card_volume = block.settings.sg_card_4_volume
              assign card_outfits = block.settings.sg_card_4_outfits
              assign card_days = block.settings.sg_card_4_days
            when 5
              assign card_name = block.settings.sg_card_5_name
              assign card_image = block.settings.sg_card_5_image
              assign card_dim = block.settings.sg_card_5_dimensions
              assign card_weight = block.settings.sg_card_5_weight
              assign card_volume = block.settings.sg_card_5_volume
              assign card_outfits = block.settings.sg_card_5_outfits
              assign card_days = block.settings.sg_card_5_days
            when 6
              assign card_name = block.settings.sg_card_6_name
              assign card_image = block.settings.sg_card_6_image
              assign card_dim = block.settings.sg_card_6_dimensions
              assign card_weight = block.settings.sg_card_6_weight
              assign card_volume = block.settings.sg_card_6_volume
              assign card_outfits = block.settings.sg_card_6_outfits
              assign card_days = block.settings.sg_card_6_days
          endcase
        -%}

        {%- if card_name != blank -%}
          <div class='size-guide-card'>
            {%- if card_image != blank -%}
              <div class='size-guide-card__image'>
                <img
                  src='{{ card_image | image_url: width: 300 }}'
                  alt='{{ card_name | escape }}'
                  width='150'
                  height='150'
                  loading='lazy'
                >
              </div>
            {%- endif -%}

            <p class='size-guide-card__name heading-font-family'>{{ card_name }}</p>

            {%- if card_dim != blank -%}
              <p class='size-guide-card__spec'>{{ card_dim }}</p>
            {%- endif -%}
            {%- if card_weight != blank -%}
              <p class='size-guide-card__spec'>{{ card_weight }}</p>
            {%- endif -%}
            {%- if card_volume != blank -%}
              <p class='size-guide-card__spec'>{{ card_volume }}</p>
            {%- endif -%}

            {%- if card_outfits != blank or card_days != blank -%}
              <div class='size-guide-card__usage'>
                {%- if card_outfits != blank -%}
                  <p class='size-guide-card__spec'>{{ card_outfits }}</p>
                {%- endif -%}
                {%- if card_days != blank -%}
                  <p class='size-guide-card__spec'>{{ card_days }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .size-guide-cards {
    width: 100%;
  }
  .size-guide-cards__heading {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1.25rem;
  }
  .size-guide-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
  }
  .size-guide-card {
    background: #f5f5f5;
    border-radius: 8px;
    padding: 16px 12px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .size-guide-card__image {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .size-guide-card__image img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
  }
  .size-guide-card__name {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 6px;
  }
  .size-guide-card__spec {
    font-size: 0.8125rem;
    margin: 0 0 2px;
    opacity: 0.7;
    line-height: 1.4;
  }
  .size-guide-card__usage {
    border-top: 1px solid rgba(0,0,0,0.1);
    margin-top: 8px;
    padding-top: 8px;
    width: 100%;
    text-align: center;
  }
{% endstylesheet %}
