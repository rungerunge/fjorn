{%- liquid
  assign options = block.settings
  assign enable_pickup_availability = options.enable_pickup_availability
  assign show_pickup_availability = false
  assign selected_variant = product.selected_or_first_available_variant
  assign available = selected_variant.available
  assign product_form_id = 'product-form-' | append: product.id | append: '-' | append: sectionId
  assign pick_up_locations = product.selected_or_first_available_variant.store_availabilities | where: 'pick_up_enabled', true
  assign pick_up_availabilities = false
  assign add_to_cart_label = 'product.store_front.add_to_cart' | t
  assign add_to_cart_label_short = 'product.store_front.add_to_cart_short' | t
  assign sold_out_label = 'product.store_front.sold_out' | t
  assign sold_out_label_short = 'product.store_front.sold_out_short' | t
  assign unavailable_label = 'product.store_front.unavailable' | t

  assign buttons_size = options.buttons_size
  assign add_to_cart_btn_style = options.add_to_cart_btn_style
  assign checkout_btn_style = options.checkout_btn_style

  for location in pick_up_locations
    if location.available == true
      assign pick_up_availabilities = true
    endif
  endfor

  assign enable_gift_card = false
  if options.enable_gift_card and product.gift_card?
    assign enable_gift_card = true
  endif

  assign show_sticky_buy_button = options.show_sticky_buy_button

  assign show_dynamic_checkout = false
  if options.show_dynamic_checkout and enable_gift_card == false
    assign show_dynamic_checkout = true
  endif

  if product.template_suffix contains 'pre-order'
    assign show_dynamic_checkout = false
    assign add_to_cart_label = 'product.store_front.pre_order' | t
    assign add_to_cart_label_short = add_to_cart_label
  endif

  if enable_pickup_availability and pick_up_availabilities == true
    unless product.template_suffix contains 'pre-order'
      assign show_pickup_availability = true
    endunless
  endif

  assign show_payment_icons = options.show_payment_icons
-%}

{%- if product != blank -%}
  <div data-product-block='{{ block.id }}' class='' {{ block.shopify_attributes }}>
    <product-form data-product-id='{{ product.id }}' id='product-form-component-{{ product.id }}-{{ sectionId }}'>
      {%- form 'product',
        product,
        id: product_form_id,
        class: 'product-form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        {% if enable_gift_card %}
          {% render 'gift-card-recipient-form', product: product, form: form, section: section, block: block %}
        {% endif %}

        <input
          type='hidden'
          name='id'
          value='{{ selected_variant.id }}'
          data-product-form-variant
          id='{{ product_form_id }}-IdInput-{{ form.id }}'
        >
        {{ form | payment_terms }}
        <div class='product-form__btns'>
          {% if template.name == 'product' and sectionId contains '---MainSection' %}
            <div class='product-form__btn-wrapper'>
              <button
                type='submit'
                name='add'
                id='product-buy-btn-{{ product.id }}-{{ sectionId }}'
                class='product-form__btn btn btn--{{buttons_size}} btn--{{add_to_cart_btn_style}}'
                {% if available != true %}
                  disabled
                {% endif %}
                aria-label='{%- if available -%}{{ add_to_cart_label | strip_html | escape }}{%- else -%}{{ sold_out_label | strip_html | escape }}{%- endif -%}'
              >
                <span data-button-text>
                  {%- if selected_variant == null -%}
                    {{ unavailable_label }}
                  {% else %}
                    {%- if available -%}
                      {{ add_to_cart_label }}
                    {%- else -%}
                      {{ sold_out_label }}
                    {%- endif -%}
                  {%- endif -%}
                </span>
                <span class='product-form__btn-price' data-btn-price-wrap>&nbsp;- <s data-btn-compare-price style='opacity:0.7;{%- unless selected_variant.compare_at_price > selected_variant.price -%}display:none;{%- endunless -%}'>{%- if selected_variant.compare_at_price > selected_variant.price -%}{{ selected_variant.compare_at_price | money }} {%- endif -%}</s><span data-btn-current-price>{{ selected_variant.price | money }}</span></span>
                <div class='loading-spinner btn__loading-spinner'></div>
              </button>
            </div>

            {% if show_sticky_buy_button != 'none' %}
              <product-form-button
                class='
                  product-form__sticky-buy-button
                  product-form__sticky-buy-button--{{ show_sticky_buy_button }}
                '
              >
                {% render 'horizontal-product-card', product: product, hide_buttons: true %}
                <div class='product-form__btn-wrapper'>
                  <button
                    type='submit'
                    name='add'
                    id='sticky-product-buy-btn-{{ product.id }}-{{ sectionId }}'
                    class='product-form__btn btn btn--sm btn--{{add_to_cart_btn_style}}'
                    {% if available != true %}
                      disabled
                    {% endif %}
                    aria-label='{%- if available -%}{{ add_to_cart_label | strip_html | escape }}{%- else -%}{{ sold_out_label | strip_html | escape }}{%- endif -%}'
                  >
                    <span data-button-text>
                      {%- if available -%}
                        <span class='product-buy-btn__text-label'> {{ add_to_cart_label }}</span>
                        <span class='product-buy-btn__text-label-short'> {{ add_to_cart_label_short }}</span>
                      {%- else -%}
                        <span class='product-buy-btn__text-label'> {{ sold_out_label }}</span>
                        <span class='product-buy-btn__text-label-short'> {{ sold_out_label_short }}</span>
                      {%- endif -%}
                    </span>
                    <div class='loading-spinner btn__loading-spinner'></div>
                  </button>
                </div>
              </product-form-button>
            {% endif %}

          {%- else -%}
            <button
              type='submit'
              name='add'
              id='product-buy-btn-{{ product.id }}-{{ sectionId }}'
              class='product-form__btn btn btn--{{buttons_size}} btn--{{add_to_cart_btn_style}}'
              {% if available != true %}
                disabled
              {% endif %}
              aria-label='{%- if available -%}{{ add_to_cart_label | strip_html | escape }}{%- else -%}{{ sold_out_label | strip_html | escape }}{%- endif -%}'
            >
              <span data-button-text>
                {%- if selected_variant == null -%}
                  {{ unavailable_label }}
                {% else %}
                  {%- if available -%}
                    {{ add_to_cart_label }}
                  {%- else -%}
                    {{ sold_out_label }}
                  {%- endif -%}
                {%- endif -%}
              </span>
              <div class='loading-spinner btn__loading-spinner'></div>
            </button>
          {% endif %}

          {%- if show_dynamic_checkout == true -%}
            <div
              class='dynamic-checkout-buttons dynamic-checkout-buttons--{{buttons_size}} dynamic-checkout-buttons--{{checkout_btn_style}}'
              {% if available != true %}
                disabled
              {% endif %}
            >
              {{ form | payment_button }}
            </div>
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>

    {%- if show_payment_icons -%}
      <div class='product-form__payment-icons-wrapper'>
        <p class='product-form__payment-icons-label'>
          {{ 'product.store_front.payment_icon_title' | t }}
        </p>

        <div class='product-form__payment-icons'>
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <script type='application/json' data-variant-prices>
      {%- for v in product.variants -%}
        {%- unless forloop.first -%},{%- endunless -%}
        { "id": {{ v.id }}, "price": {{ v.price }}, "compare": {{ v.compare_at_price | default: 0 }} }
      {%- endfor -%}
    </script>
    <script>
      (function() {
        const wrap = document.currentScript.closest('[data-product-block]');
        if (!wrap) return;
        const pricesJson = wrap.querySelector('[data-variant-prices]');
        if (!pricesJson) return;
        const variants = JSON.parse('[' + pricesJson.textContent + ']');
        const variantMap = {};
        variants.forEach(v => { variantMap[v.id] = v; });
        const fmt = cents => (cents / 100).toLocaleString('da-DK', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' kr';
        const fmtKr = kr => kr.toLocaleString('da-DK', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' kr';

        /* ── Tier pricing from bundle config ── */
        const section = wrap.closest('.shopify-section');
        const bvp = section ? section.querySelector('bundle-variant-picker') : null;
        let tierData = [];
        let getTierPricesForVariant = null;

        if (bvp) {
          try { tierData = JSON.parse(bvp.querySelector('[data-bundle-tiers]')?.textContent || '[]'); } catch(e) {}
          tierData.sort((a, b) => a.count - b.count);

          getTierPricesForVariant = function(vid) {
            const item = bvp.querySelector('[data-variant-id="' + vid + '"]');
            if (!item) return null;
            const raw = item.dataset.tierPrices;
            if (!raw) return null;
            try { return JSON.parse(raw); } catch(e) { return null; }
          };
        }

        function getCurrentTierIndex(qty) {
          if (!tierData.length) return 0;
          let idx = 0;
          for (const t of tierData) { if (qty >= t.count) idx = t.index; }
          return idx;
        }

        let currentVid = null;

        function update(vid, qty) {
          currentVid = vid;
          const v = variantMap[vid];
          if (!v) return;
          qty = qty || 1;

          let unitPrice = v.price / 100;
          let comparePrice = v.compare > v.price ? v.compare / 100 : v.price / 100;
          let hasTierDiscount = false;

          if (getTierPricesForVariant && tierData.length > 0) {
            const tierPrices = getTierPricesForVariant(vid);
            if (tierPrices) {
              const tierIdx = getCurrentTierIndex(qty);
              const tierPrice = tierPrices[tierIdx];
              if (tierPrice > 0) {
                unitPrice = tierPrice;
                if (v.compare > v.price) {
                  comparePrice = v.compare / 100;
                } else {
                  const tier0Price = tierPrices[0] > 0 ? tierPrices[0] : v.price / 100;
                  comparePrice = tier0Price;
                }
                hasTierDiscount = comparePrice > unitPrice;
              }
            }
          }

          const totalPrice = unitPrice * qty;
          const totalCompare = comparePrice * qty;
          const hasCompare = hasTierDiscount || (v.compare > v.price);

          wrap.querySelectorAll('[data-btn-current-price]').forEach(el => { el.textContent = fmtKr(totalPrice); });
          wrap.querySelectorAll('[data-btn-compare-price]').forEach(el => {
            el.textContent = hasCompare ? fmtKr(totalCompare) + ' ' : '';
            el.style.display = hasCompare ? '' : 'none';
          });
        }

        function getQty() {
          const pi = wrap.closest('.product__info') || document;
          const qtyInput = pi.querySelector('[data-quantity-input]');
          return qtyInput ? parseInt(qtyInput.value) || 1 : 1;
        }

        const hiddenInput = wrap.querySelector('[data-product-form-variant]');
        if (hiddenInput) {
          new MutationObserver(() => update(hiddenInput.value, getQty())).observe(hiddenInput, { attributes: true, attributeFilter: ['value'] });
          update(hiddenInput.value, getQty());
        }

        document.addEventListener('variant:change', e => {
          if (e.detail?.variant?.id) update(e.detail.variant.id, getQty());
        });

        /* Listen for quantity changes */
        const pi = wrap.closest('.product__info') || document;
        const qtyInput = pi.querySelector('[data-quantity-input]');
        if (qtyInput) {
          const onQtyChange = () => { if (currentVid) update(currentVid, parseInt(qtyInput.value) || 1); };
          qtyInput.addEventListener('change', onQtyChange);
          qtyInput.addEventListener('input', onQtyChange);
          new MutationObserver(() => onQtyChange()).observe(qtyInput, { attributes: true, attributeFilter: ['value'] });
        }
      })();
    </script>

    {%- if show_pickup_availability == true -%}
      <pickup-availability
        class='pickup-availability body-font-weight-from-global-settings'
        data-base-url='{{ shop.url }}{{ routes.root_url }}'
        data-variant-id='{{ selected_variant.id }}'
        data-has-only-default-variant='{{ product.has_only_default_variant }}'
        id='product-pickup-availability-{{ product.id }}-{{ sectionId }}'
      >
        <pickup-availability-content class='pickup-availability-info'> </pickup-availability-content>
      </pickup-availability>
    {%- endif -%}
  </div>
{%- endif -%}
