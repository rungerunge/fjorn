            "body_size": "body3",
            "media_type": "image",
            "image_width": 100
          }
        },
        "question_xQBg74": {
          "type": "question",
          "settings": {
            "title": "Hvad koster fragt?",
            "heading_size": "caption2",
            "icon_type": "none",
            "icon": "settings",
            "icon_size": 24,
            "text": "<p>Der er gratis fragt på ordre over 599kr. Fragtprisen afhænger af leveringsmetode og destination. Du kan altid se den endelige fragtpris, inden du gennemfører din ordre.</p>",
            "page": "",
            "body_size": "body3",
            "media_type": "image",
            "image_width": 100
          }
        },
        "question_LH8mJw": {
          "type": "question",
          "settings": {
            "title": "Hvor lang returret har jeg?",
            "heading_size": "caption2",
            "icon_type": "none",
            "icon": "settings",
            "icon_size": 24,
            "text": "<p>Du har 30 dages returret på ubrugte varer i original emballage - kontakt os for at starte din returnering.</p>",
