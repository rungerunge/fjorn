        },
        "question_CiCCfx": {
          "type": "question",
          "settings": {
            "title": "Hvor lang tid tager levering?",
            "heading_size": "caption2",
            "icon_type": "none",
            "icon": "settings",
            "icon_size": 24,
            "text": "<p>Den typisk estimerede leveringstid er 1-5 dage.</p>",
